{
  "headers": [
    {
      "source": "/assets/fonts/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "https://marcelinasespaco.com.br/:path*",
      "destination": "https://www.marcelinasespaco.com.br/:path*",
      "permanent": true
    }
  ]
}