{
  "headers": [
    {
      "source": "/assets/fonts/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.marcelinasespaco.com.br"
        }
      ],
      "destination": "https://marcelinasespaco.com.br/:path*",
      "permanent": true
    }
  ]
}